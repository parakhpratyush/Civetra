rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      // Robust admin check: Check if email exists in admin collection OR uid exists in admin collection
      // We also check if the role field is 'admin' if possible
      return request.auth != null && (
        exists(/databases/$(database)/documents/admin/$(request.auth.token.email)) ||
        exists(/databases/$(database)/documents/admin/$(request.auth.uid))
      );
    }

    match /issues/{document=**} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if isAdmin();
    }
    
    match /community_posts/{document=**} {
      allow read: if true;
      allow create, update, delete: if isAdmin(); 
    }
    
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null; 
    }
    
    match /campaigns/{document=**} {
      allow read: if true;
      allow create, update, delete: if isAdmin() || request.auth != null;
    }

    match /volunteers/{document=**} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    
    match /admin/{adminId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
